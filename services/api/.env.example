# 本地开发：先在本机启动 Postgres（可用仓库根目录 docker compose up -d postgres）
DATABASE_URL="postgresql://playmate:playmate@localhost:5432/playmate?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000

# 微信小程序：用于 access_token + 手机号快速验证（getPhoneNumber → getuserphonenumber）
# 登录仅支持手机号；生产环境必须配置
# https://developers.weixin.qq.com/miniprogram/dev/framework/open-ability/getPhoneNumber.html
WECHAT_MINI_APPID=""
WECHAT_MINI_SECRET=""
