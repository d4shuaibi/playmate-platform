# 本地开发：先在本机启动 Postgres（可用仓库根目录 docker compose up -d postgres）
DATABASE_URL="postgresql://playmate:playmate@localhost:5432/playmate?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000

# 微信小程序：用于 access_token + 手机号快速验证（getPhoneNumber → getuserphonenumber）
# 登录仅支持手机号；生产环境必须配置
# https://developers.weixin.qq.com/miniprogram/dev/framework/open-ability/getPhoneNumber.html
WECHAT_MINI_APPID=""
WECHAT_MINI_SECRET=""

# 微信支付商户 API v3（小程序 JSAPI）。流程见：https://pay.weixin.qq.com/doc/v3/merchant/4012791911
# notify_url 填：{公网 API}/api/wechat-pay/notify
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_MERCHANT_CERT_SERIAL=""
WECHAT_PAY_PRIVATE_KEY=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_NOTIFY_URL=""
# 未配置完整商户参数时视为模拟支付；生产配置齐全后设为 false 走真实预下单
WECHAT_PAY_DEV_SIMULATE="true"

# 微信支付公钥（https://pay.weixin.qq.com/doc/v3/partner/4012925323）：回调验签 + 请求带 Wechatpay-Serial
# WECHAT_PAY_PUBLIC_KEY_ID：商户平台下载 pub_key 后展示的公钥 ID（请求头 / 回调验签白名单）
# WECHAT_PAY_PUBLIC_KEY_PATH：pub_key.pem 路径；或与 WECHAT_PAY_PUBLIC_KEY_PEM（整条 PEM）二选一
# WECHAT_PAY_PUBLIC_KEY_ID_ALLOWLIST：多个公钥 ID 逗号分隔（轮换）；默认使用 WECHAT_PAY_PUBLIC_KEY_ID
# WECHAT_PAY_SKIP_NOTIFY_VERIFY=true：跳过回调验签（仅本地调试）
WECHAT_PAY_PUBLIC_KEY_ID=""
WECHAT_PAY_PUBLIC_KEY_PATH=""

# 登录态签名与有效期（access_token + refresh_token）
JWT_SECRET="replace-with-strong-secret"
JWT_ACCESS_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="30d"

# 管理端登录（challenge-proof，避免明文密码上传）
# passwordHash = sha256(明文密码)，proof = sha256(passwordHash + "." + nonce)
# 示例账号：admin / Admin#2026（仅开发环境默认内置；生产必须显式配置）
ADMIN_JWT_SECRET="replace-with-strong-admin-secret"
ADMIN_JWT_ACCESS_EXPIRES_IN="30m"
ADMIN_JWT_REFRESH_EXPIRES_IN="7d"
# e.g.
# ADMIN_AUTH_ACCOUNTS_JSON='[
#   {
#     "username":"admin",
#     "displayName":"平台老板",
#     "passwordHash":"<sha256-hex>",
#     "role":"owner",
#     "permissions":[
#       "system_overview.view","admin.manage",
#       "dashboard.view","product.read","product.write","order.read","order.dispatch","order.write",
#       "worker.read","worker.audit","worker.write","customer_service.read","customer_service.write",
#       "settings.read","settings.write"
#     ]
#   },
#   {
#     "username":"ops01",
#     "displayName":"运营管理员",
#     "passwordHash":"<sha256-hex>",
#     "role":"admin",
#     "permissions":[
#       "dashboard.view","product.read","product.write","order.read","order.dispatch","order.write",
#       "worker.read","worker.audit","worker.write","customer_service.read","customer_service.write",
#       "settings.read","settings.write"
#     ]
#   },
#   {
#     "username":"cs01",
#     "displayName":"客服一号",
#     "passwordHash":"<sha256-hex>",
#     "role":"customer_service",
#     "permissions":["dashboard.view","product.read","order.read","order.dispatch","worker.read","worker.audit"]
#   }
# ]'
ADMIN_AUTH_ACCOUNTS_JSON=""
