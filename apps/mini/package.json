{
  "name": "@playmate/mini",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:weapp": "cross-env NODE_ENV=development node scripts/dev-weapp.cjs",
    "dev:weapp:prod": "cross-env NODE_ENV=production node scripts/dev-weapp.cjs",
    "build:weapp": "cross-env NODE_ENV=production taro build --type weapp && node scripts/patch-taro-jsx.cjs",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "type-check": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run type-check"
  },
  "dependencies": {
    "@tarojs/components": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@eslint/js": "^9.35.0",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^7.0.3",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^4.5.14"
  }
}
